# DevOps Configuration Template
# Copy this file to .env and update values for your environment

# Server Configuration
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8081
PORT=8081
SPRING_PROFILES_ACTIVE=qa

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cloud_kitchen_rbac
DB_USERNAME=postgres
DB_PASSWORD=aspire123
POSTGRES_DB=cloud_kitchen_rbac
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Application Configuration
DATABASE_URL=jdbc:postgresql://postgres:5432/cloud_kitchen_rbac

# JWT Configuration
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_for_security
JWT_ACCESS_EXPIRY=3600
JWT_REFRESH_EXPIRY=86400
